<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.songhg.firefly.iot.system.mapper.ApiKeyMapper">

    <select id="findByAccessKey" resultType="com.songhg.firefly.iot.system.entity.ApiKey">
        SELECT *
        FROM api_keys
        WHERE access_key = #{accessKey}
          AND deleted_at IS NULL
        LIMIT 1
    </select>

</mapper>
