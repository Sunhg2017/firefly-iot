# ============================================================
# Firefly IoT deployment environment template
# Copy to `.env` and update values for your environment.
# ============================================================

# ---------- Global ----------
COMPOSE_PROJECT_NAME=firefly-iot
DEPLOY_ENV=prod
# Docker-style .env parsing is supported here, so values with spaces can stay unquoted.
JAVA_OPTS=-Xms256m -Xmx512m
# Keep persistent volumes on stable names so the current compose project can
# take over hosts that were once started from another directory/project name.
POSTGRES_VOLUME_NAME=firefly-postgres-data
REDIS_VOLUME_NAME=firefly-redis-data
KAFKA_VOLUME_NAME=firefly-kafka-data
MINIO_VOLUME_NAME=firefly-minio-data
CONNECTOR_MQTT_VOLUME_NAME=firefly-connector-mqtt-data

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=firefly_iot
POSTGRES_USER=firefly
POSTGRES_PASSWORD=firefly123
POSTGRES_MAX_CONNECTIONS=300
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1
DB_POOL_CONNECTION_TIMEOUT_MS=10000
DB_POOL_IDLE_TIMEOUT_MS=60000
DB_POOL_MAX_LIFETIME_MS=1800000
FLYWAY_CONNECT_RETRIES=30

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- Kafka ----------
KAFKA_SERVERS=kafka:9092

# ---------- Nacos ----------
NACOS_ADDR=nacos:8848
NACOS_NAMESPACE=firefly-prod

# ---------- MinIO ----------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=firefly-iot

# ---------- Sentinel ----------
SENTINEL_DASHBOARD=sentinel:8858

# ---------- JWT ----------
JWT_PUBLIC_KEY=

# ---------- Embedded MQTT in firefly-connector ----------
FIREFLY_HTTP_PRESENCE_TIMEOUT_SECONDS=300
FIREFLY_HTTP_PRESENCE_SWEEP_INTERVAL_SECONDS=30
FIREFLY_MQTT_ENABLED=true
FIREFLY_MQTT_HOST=0.0.0.0
FIREFLY_MQTT_PORT=1883
FIREFLY_MQTT_ALLOW_ANONYMOUS=false
FIREFLY_MQTT_PERSISTENCE_ENABLED=false
FIREFLY_MQTT_DATA_PATH=data/mqtt
FIREFLY_MQTT_MAX_MESSAGE_SIZE=65536
# Leave blank to auto-generate from POD_NAME / HOSTNAME / HOST + port.
FIREFLY_MQTT_NODE_ID=
# Leave blank to use the default group: firefly-connector-mqtt-downstream.
FIREFLY_MQTT_DOWNSTREAM_GROUP=
FIREFLY_MQTT_ROUTE_TTL_SECONDS=120
FIREFLY_MQTT_ROUTE_REFRESH_INTERVAL_SECONDS=30
FIREFLY_MQTT_NODE_HEARTBEAT_TTL_SECONDS=45
FIREFLY_MQTT_NODE_HEARTBEAT_INTERVAL_SECONDS=15
FIREFLY_MQTT_DOWNSTREAM_QOS=1
FIREFLY_MQTT_RELAY_CHANNEL_PREFIX=connector:mqtt:downstream:

# ---------- ZLMediaKit ----------
# Compose now builds a pinned ZLMediaKit 8.0 image locally instead of pulling
# `zlmediakit/zlmediakit:master`, so the REST API continues to use `secret=...`.
# `ZLM_HOST` / `ZLM_PUBLIC_HOST` must be reachable by cameras and browsers.
# Local debugging can keep `localhost`; production should use the server IP or DNS.
ZLM_HOST=localhost
ZLM_PUBLIC_HOST=localhost
ZLM_API_HOST=zlmediakit
ZLM_API_PORT=80
ZLM_PORT=18080
ZLM_PUBLIC_PORT=18080
ZLM_SSL_PORT=18443
ZLM_PUBLIC_SSL_PORT=18443
ZLM_RTSP_PORT=18554
ZLM_RTMP_PORT=1935
ZLM_RTP_PORT=10000
ZLM_SECRET=035c73f7bb6b4889a715d9eb2d1925cc

# ---------- Mail / Notification ----------
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# ---------- Frontend ----------
VITE_API_BASE_URL=/api
